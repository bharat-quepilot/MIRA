# Python — never ship the host venv or caches into the image
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Secrets — keys must come from docker-compose env_file at runtime, not the image
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# VCS
.git/
.gitignore

# Build artifacts / scratch
dist/
build/
*.log
