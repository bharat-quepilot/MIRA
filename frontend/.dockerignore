# Node — never ship host deps; the image runs `npm install` itself
node_modules/
.next/
out/
dist/
build/

# Secrets — runtime env vars come via docker-compose, not baked into the image
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/

# VCS
.git/
.gitignore

# Misc
*.tsbuildinfo
